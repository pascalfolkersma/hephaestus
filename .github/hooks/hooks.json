{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/dispatch-enforce.js",
        "timeout": 15
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "node .github/hooks/subagent-tracker.js",
        "timeout": 5
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "node .github/hooks/subagent-tracker.js",
        "timeout": 5
      }
    ]
  }
}
